    "Chaos Space Marines": ["chaos space marines", "heretic astartes"],
    "Orks": ["orks?"],
    "Tyranids": ["tyranids?", "hive mind"],
    "Necrons": ["necrons?"],
    "T'au Empire": ["t'?au empire", "tau empire"],
    "Drukhari": ["drukhari", "dark eldar"],
    "Adeptus Mechanicus": ["adeptus mechanicus", "admech"],
    "Adeptus Custodes": ["adeptus custodes", "custodes"],
    "Grey Knights": ["grey knights"],
    "Dark Angels": ["dark angels"],
    "Blood Angels": ["blood angels"],
    "Space Wolves": ["space wolves"],
    "Black Templars": ["black templars"],
    "Deathwatch": ["deathwatch"],
    "Thousand Sons": ["thousand sons"],
    "World Eaters": ["world eaters"],
    "Chaos Daemons": ["chaos daemons", "daemons of chaos"],
    "Imperial Knights": ["imperial knights"],
    "Chaos Knights": ["chaos knights"],
    "Leagues of Votann": ["leagues of votann", "votann"],
